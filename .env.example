# Hackathon Aggregator Environment Configuration
# Copy this file to .env and replace the placeholder values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/hackathon-aggregator

# Google Gemini API Key (get from https://aistudio.google.com/)
# You can use either GEMINI_API_KEY or API_KEY
GEMINI_API_KEY=your_actual_gemini_api_key_here
# API_KEY=your_actual_gemini_api_key_here

# Server configuration
PORT=3000
NODE_ENV=development

# API rate limiting
DAILY_REQUEST_LIMIT=1000

# Optional: For production environments
# NODE_ENV=production